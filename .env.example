KAFKA_BROKER=192.168.1.199:9092
KAFKA_TOPIC=ai.metadata.v1
KAFKA_GROUP_ID=vehicle-capture-service
KAFKA_OFFSET=latest

CONFIDENCE_THRESHOLD=0.99
CROP_EXPAND_RATIO=0.30
COOLDOWN_SEC=60
MAX_EVENT_AGE_SEC=120

